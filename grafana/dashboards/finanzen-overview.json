        {
          "datasource": {
            "type": "mysql",
            "uid": "MariaDB"
          },
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT \n  UNIX_TIMESTAMP(DATE_FORMAT(date, '%Y-%m-01')) as time,\n  SUM(CASE WHEN amount > 0 THEN amount ELSE 0 END) as 'Einnahmen',\n  ABS(SUM(CASE WHEN amount < 0 THEN amount ELSE 0 END)) as 'Ausgaben',\n  SUM(amount) as 'Saldo'\nFROM transactions\nWHERE $__timeFilter(date)\nGROUP BY DATE_FORMAT(date, '%Y-%m')\nORDER BY time",
          "refId": "A"
        }
      ],
      "title": "Einnahmen vs. Ausgaben (12 Monate)",
      "type": "timeseries"
