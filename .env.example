# =================================================================
# FINANZEN APP - UMGEBUNGSVARIABLEN
# =================================================================
# WICHTIG: Diese Datei niemals in Git einchecken!

# =================================================================
# DATENBANK-KONFIGURATION (MariaDB)
# =================================================================
DB_TYPE=mariadb
DB_HOST=finanzen_db
DB_PORT=3306
DB_NAME=finanzen
DB_USER=finanzen
DB_PASSWORD=change_me_secure_password
DB_ROOT_PASSWORD=change_me_root_password

# =================================================================
# POSTBANK FINTS-ZUGANGSDATEN
# =================================================================
# WICHTIG: Ihre echten Postbank-Zugangsdaten hier eintragen!
POSTBANK_LOGIN=Ihr_Postbank_Login
POSTBANK_PIN=Ihre_Postbank_PIN

# =================================================================
# FINTS/HBCI KONFIGURATION
# =================================================================
FINTS_PRODUCT_ID=FINANZEN_APP_1.0
FINTS_PRODUCT_VERSION=1.0

# =================================================================
# VERSCHLÜSSELUNG & SICHERHEIT
# =================================================================
ENCRYPTION_KEY=generate_a_secure_key_here

# =================================================================
# GRAFANA (Pflicht für docker compose / deploy.sh)
# =================================================================
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=set_a_strong_password_here
# Optional: öffentliche URL für Grafana
# GRAFANA_ROOT_URL=http://finanzen.example.com:3000

# =================================================================
# DOCKER COMPOSE (optional, aber wichtig für energie_monitor + Grafana)
# =================================================================
# Alle Services eines Stacks müssen denselben Compose-Projektnamen nutzen, sonst hängen
# Container in getrennten Netzen (Grafana erreicht energie_monitor dann nicht per DNS).
# Wenn du z.B. schon einen Stack mit Projekt „finanzen“ hast, setze dasselbe hier:
# COMPOSE_PROJECT_NAME=finanzen
#
# Host-Port für die Energie-API (OpenAPI unter /docs), siehe docker-compose.energie-monitor.yml
# ENERGIE_HOST_PORT=8080

# =================================================================
# OLLAMA (PDF-Transaktionsextraktion per LLM, optional)
# =================================================================
# Host wo Ollama läuft (z.B. openclaw). Aktivierung in config/settings.yaml: ollama.enabled: true
OLLAMA_HOST=http://openclaw:11434

# =================================================================
# SYSTEM-KONFIGURATION
# =================================================================
TZ=Europe/Berlin

# =================================================================
# WEITERE BANKEN (falls später hinzugefügt)
# =================================================================
# SPARKASSE_LOGIN=
# SPARKASSE_PIN=
# COMMERZBANK_LOGIN=
# COMMERZBANK_PIN=

# Logging
LOG_LEVEL=INFO
